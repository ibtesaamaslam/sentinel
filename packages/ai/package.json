  "dependencies": { "@sentinel/core": "workspace:*", "@sentinel/logger": "workspace:*", "@sentinel/config": "workspace:*" },
  "devDependencies": { "@types/node": "^26.0.1", "typescript": "^6.0.3", "vitest": "^4.1.9" }
}
