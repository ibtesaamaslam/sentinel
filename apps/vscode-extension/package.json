{
  "name": "@sentinel/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Sentinel VS Code Extension - In-editor AI code safety verification",
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": { "build": "tsc", "dev": "tsc --watch", "typecheck": "tsc --noEmit", "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"", "test": "vitest run" },
  "dependencies": { "@sentinel/core": "workspace:*", "@sentinel/scanner": "workspace:*", "@sentinel/monitor": "workspace:*" },
  "devDependencies": { "@types/node": "^26.0.1", "typescript": "^6.0.3", "vitest": "^4.1.9" }
}
